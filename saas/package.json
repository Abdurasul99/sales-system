{
  "name": "sales-system",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "(node ./scripts/run-local-js.mjs ./node_modules/next/dist/bin/next dev) || (\"%npm_node_execpath%\" ./scripts/run-local-js.mjs ./node_modules/next/dist/bin/next dev)",
    "build": "(node ./scripts/build.mjs) || (\"%npm_node_execpath%\" ./scripts/build.mjs)",
    "start": "(node ./scripts/run-local-js.mjs ./node_modules/next/dist/bin/next start) || (\"%npm_node_execpath%\" ./scripts/run-local-js.mjs ./node_modules/next/dist/bin/next start)",
    "lint": "(node ./scripts/run-local-js.mjs ./node_modules/next/dist/bin/next lint) || (\"%npm_node_execpath%\" ./scripts/run-local-js.mjs ./node_modules/next/dist/bin/next lint)",
    "typecheck": "(node ./scripts/run-local-js.mjs ./node_modules/typescript/bin/tsc --noEmit) || (\"%npm_node_execpath%\" ./scripts/run-local-js.mjs ./node_modules/typescript/bin/tsc --noEmit)",
    "db:push": "echo Blocked: use Prisma migrations instead of prisma db push. && exit 1",
    "db:validate": "(node ./scripts/run-prisma.mjs validate) || (\"%npm_node_execpath%\" ./scripts/run-prisma.mjs validate)",
    "db:migrate": "(node ./scripts/run-prisma.mjs migrate dev) || (\"%npm_node_execpath%\" ./scripts/run-prisma.mjs migrate dev)",
    "db:migrate:deploy": "(node ./scripts/run-prisma.mjs migrate deploy) || (\"%npm_node_execpath%\" ./scripts/run-prisma.mjs migrate deploy)",
    "db:migrate:status": "(node ./scripts/run-prisma.mjs migrate status) || (\"%npm_node_execpath%\" ./scripts/run-prisma.mjs migrate status)",
    "db:seed": "(node ./scripts/run-local-js.mjs ./node_modules/tsx/dist/cli.mjs prisma/seed.ts) || (\"%npm_node_execpath%\" ./scripts/run-local-js.mjs ./node_modules/tsx/dist/cli.mjs prisma/seed.ts)",
    "db:studio": "(node ./scripts/run-prisma.mjs studio) || (\"%npm_node_execpath%\" ./scripts/run-prisma.mjs studio)",
    "db:generate": "(node ./scripts/run-prisma.mjs generate) || (\"%npm_node_execpath%\" ./scripts/run-prisma.mjs generate)",
    "plan:check": "(node ./scripts/run-local-js.mjs ./node_modules/tsx/dist/cli.mjs scripts/plan-check.ts) || (\"%npm_node_execpath%\" ./scripts/run-local-js.mjs ./node_modules/tsx/dist/cli.mjs scripts/plan-check.ts)",
    "test": "(node ./scripts/test-pipeline.mjs) || (\"%npm_node_execpath%\" ./scripts/test-pipeline.mjs)",
    "test:unit": "(node ./scripts/run-local-js.mjs ./node_modules/vitest/vitest.mjs run --config vitest.unit.config.ts) || (\"%npm_node_execpath%\" ./scripts/run-local-js.mjs ./node_modules/vitest/vitest.mjs run --config vitest.unit.config.ts)",
    "test:integration": "(node ./scripts/run-local-js.mjs ./node_modules/vitest/vitest.mjs run --config vitest.integration.config.ts) || (\"%npm_node_execpath%\" ./scripts/run-local-js.mjs ./node_modules/vitest/vitest.mjs run --config vitest.integration.config.ts)",
    "test:e2e": "(node ./scripts/run-local-js.mjs ./node_modules/tsx/dist/cli.mjs scripts/smoke.ts) || (\"%npm_node_execpath%\" ./scripts/run-local-js.mjs ./node_modules/tsx/dist/cli.mjs scripts/smoke.ts)",
    "diagnose:runtime": "(node ./scripts/runtime-diagnostics.mjs) || (\"%npm_node_execpath%\" ./scripts/runtime-diagnostics.mjs)",
    "test:watch": "(node ./scripts/run-local-js.mjs ./node_modules/vitest/vitest.mjs) || (\"%npm_node_execpath%\" ./scripts/run-local-js.mjs ./node_modules/vitest/vitest.mjs)",
    "verify": "(node ./scripts/verify.mjs) || (\"%npm_node_execpath%\" ./scripts/verify.mjs)",
    "release:check": "(node ./scripts/release-pipeline.mjs) || (\"%npm_node_execpath%\" ./scripts/release-pipeline.mjs)"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-avatar": "^1.1.1",
    "@radix-ui/react-checkbox": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.2",
    "@radix-ui/react-scroll-area": "^1.2.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.2",
    "@radix-ui/react-tooltip": "^1.1.3",
    "@tanstack/react-query": "^5.59.0",
    "@tanstack/react-table": "^8.20.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20",
    "@types/numeral": "^2.0.5",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10",
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cookies-next": "^4.3.0",
    "date-fns": "^4.1.0",
    "jose": "^5.9.6",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.460.0",
    "next": "14.2.18",
    "next-themes": "^0.4.3",
    "numeral": "^2.0.6",
    "postcss": "^8",
    "prisma": "^5.22.0",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.53.2",
    "react-hot-toast": "^2.4.1",
    "recharts": "^2.13.0",
    "tailwind-merge": "^2.5.4",
    "tailwindcss": "^3.4.14",
    "typescript": "^5",
    "zod": "^3.23.8",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.18",
    "jsdom": "^29.0.0",
    "tsx": "^4.19.1",
    "vitest": "^2.1.9"
  }
}
